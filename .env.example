# ==============================================================================
# KnowledgeHub AI - Environment Configuration Template
# ==============================================================================
# Copy this file to .env and fill in the required values.
# Do NOT commit the actual .env file containing real secrets to version control!

# ------------------------------------------------------------------------------
# 1. FastAPI Application Settings
# ------------------------------------------------------------------------------
PROJECT_NAME="KnowledgeHub AI"
ENVIRONMENT="development"  # "development" or "production"
API_V1_STR="/api/v1"
BACKEND_CORS_ORIGINS='["http://localhost:5173", "http://localhost:3000", "http://127.0.0.1:5173"]'

# ------------------------------------------------------------------------------
# 2. Database (PostgreSQL) Settings
# ------------------------------------------------------------------------------
POSTGRES_SERVER="postgres" # Use "localhost" if running backend outside Docker
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="secure_postgres_password_here"
POSTGRES_DB="knowledgehub"
POSTGRES_PORT=5432
DATABASE_URL="postgresql+asyncpg://postgres:secure_postgres_password_here@postgres:5432/knowledgehub"

# ------------------------------------------------------------------------------
# 3. Vector Database (Qdrant) Settings
# ------------------------------------------------------------------------------
QDRANT_HOST="qdrant" # Use "localhost" if running backend outside Docker
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION_NAME="knowledgehub_embeddings"

# ------------------------------------------------------------------------------
# 4. Security & JWT Settings
# ------------------------------------------------------------------------------
JWT_SECRET_KEY="replace_with_a_very_long_random_hex_string_in_production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Argon2id Security Parameters (OWASP Recommended Defaults)
ARGON2_TIME_COST=2
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# ------------------------------------------------------------------------------
# 5. LLM API Keys (Google Gemini)
# ------------------------------------------------------------------------------
# Get your Gemini API Key from: https://aistudio.google.com/
GEMINI_API_KEY="your_google_gemini_api_key_goes_here"
GEMINI_MODEL_NAME="gemini-2.0-flash"

# ------------------------------------------------------------------------------
# 6. File Upload Constraints
# ------------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR="./uploads"

# ------------------------------------------------------------------------------
# 7. Rate Limiting Settings
# ------------------------------------------------------------------------------
RATE_LIMIT_DEFAULT="60/minute"
RATE_LIMIT_AUTH="5/minute"
